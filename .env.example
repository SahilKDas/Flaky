# Optional locally. With no key, the UI clearly labels deterministic demo output.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
# Used only when the primary live model is rate-limited or temporarily overloaded.
GEMINI_FALLBACK_MODEL=gemini-3.1-flash-lite
# Never silently substitute demo output when a configured Gemini request fails.
AI_DEMO_FALLBACK=false
